#!/usr/bin/env bash

if ! command -v opm-version &> /dev/null; then
PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" || exit; pwd):$PATH"
fi

if ! command -v opy-nebula1-uploadserver &> /dev/null; then
    opm-println-error "Not found opy-nebula1-uploadserver command"
    exit 1
fi

opy-nebula1-uploadserver "$@"
