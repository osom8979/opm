#!/usr/bin/env bash

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
ENV_FILE="$ROOT_DIR/.env"
TEMPLATE_FILE="$ROOT_DIR/env-template"

red()   { printf "\033[1;31m%s\033[0m\n" "$*"; }
green() { printf "\033[1;32m%s\033[0m\n" "$*"; }

if [ -f "$ENV_FILE" ]; then
    red ".env already exists: $ENV_FILE"
    red "Remove it first if you want to regenerate."
    exit 1
fi

if [ ! -f "$TEMPLATE_FILE" ]; then
    red "Template not found: $TEMPLATE_FILE"
    exit 1
fi

AIRFLOW_UID="$(id -u)"
AIRFLOW_WWW_USER_PASSWORD="$(openssl rand -hex 16)"

sed \
    -e "s/@AIRFLOW_UID@/$AIRFLOW_UID/g" \
    -e "s/@AIRFLOW_WWW_USER_PASSWORD@/$AIRFLOW_WWW_USER_PASSWORD/g" \
    "$TEMPLATE_FILE" > "$ENV_FILE"

if [[ $? -eq 0 ]]; then
    green "Generated: $ENV_FILE"
else
    red "Failed to generate .env"
    exit 1
fi
