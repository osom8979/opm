#!/usr/bin/env bash

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
ENV_FILE="$ROOT_DIR/.env"
TEMPLATE_FILE="$ROOT_DIR/env-template"

red()   { printf "\033[1;31m%s\033[0m\n" "$*"; }
green() { printf "\033[1;32m%s\033[0m\n" "$*"; }

if [ -f "$ENV_FILE" ]; then
    red ".env already exists: $ENV_FILE"
    red "Remove it first if you want to regenerate."
    exit 1
fi

if [ ! -f "$TEMPLATE_FILE" ]; then
    red "Template not found: $TEMPLATE_FILE"
    exit 1
fi

cp "$TEMPLATE_FILE" "$ENV_FILE"

if [[ $? -eq 0 ]]; then
    green "Generated: $ENV_FILE"
else
    red "Failed to generate .env"
    exit 1
fi

# Create default config.json if it doesn't exist
CONFIG_FILE="$ROOT_DIR/config.json"
if [ ! -f "$CONFIG_FILE" ]; then
    cat > "$CONFIG_FILE" <<'EOF'
{
  "defaultWiki": "en.wikipedia.org",
  "wikis": {
    "en.wikipedia.org": {
      "sitename": "Wikipedia",
      "server": "https://en.wikipedia.org",
      "articlepath": "/wiki",
      "scriptpath": "/w",
      "token": null,
      "username": null,
      "password": null,
      "private": false
    }
  }
}
EOF
    green "Created default config.json"
    green "Edit $CONFIG_FILE to configure your wikis."
else
    green "config.json already exists, skipping."
fi
